<configuration>

    <!-- 1. Define a timestamp variable in the preferred format -->
    <timestamp key="byCurrentTime" datePattern="yyyyMMdd_HHmmss"/>

    <!-- 2. Configure the File Appender -->
    <appender name="FILE" class="ch.qos.logback.core.FileAppender">
        <!-- Change 'C:/my_logs/' to your preferred local folder path -->
        <file>C:/my_logs/log_${byCurrentTime}.log</file>
        <append>true</append>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 3. Configure the Console Appender (Optional, to see logs in IDE) -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 4. Set the Root Logger Level and link the appenders -->
    <root level="INFO">
        <appender-ref ref="FILE" />
        <appender-ref ref="CONSOLE" />
    </root>

</configuration>